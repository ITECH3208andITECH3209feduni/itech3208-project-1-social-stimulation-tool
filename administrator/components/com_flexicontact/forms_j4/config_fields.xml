<?xml version="1.0" encoding="utf-8"?>
<form>
   	<fieldset name="main" class="lad-fieldset width-auto" >
    
        <field name="subject_heading" type="note" label="COM_FLEXICONTACT_ADMIN_SUBJECT" />
        <field name="show_subject" type="radio" default="1" label="COM_FLEXICONTACT_V_SHOW_SUBJECT"
            layout="joomla.form.field.radio.switcher" >
            <option value="0">JNO</option>
            <option value="1">JYES</option>
        </field>
        <field name="default_subject" type="text" label="COM_FLEXICONTACT_V_DEFAULT_SUBJECT" default="" />

        <field name="message-heading" type="note" class="fc_top_border" label="COM_FLEXICONTACT_MESSAGE" />
        <field name="area_opt" type="list" default="1" label="COM_FLEXICONTACT_MESSAGE"
            description="COM_FLEXICONTACT_V_TEXT_AREA_DESC" >
            <option value="disabled">COM_FLEXICONTACT_V_DISABLED</option>
            <option value="optional">COM_FLEXICONTACT_V_OPTIONAL</option>
            <option value="mandatory">COM_FLEXICONTACT_V_MANDATORY</option>
        </field>
        <field name="area_prompt" type="text" label="COM_FLEXICONTACT_V_PROMPT" default="" />
        <field name="area_height" type="number" min="1" max="500" label="COM_FLEXICONTACT_V_HEIGHT" default="" />            

        <field name="list-heading" type="note" class="fc_top_border" label="COM_FLEXICONTACT_LIST" />
        <field name="list_opt" type="list" default="1" label="COM_FLEXICONTACT_LIST" description="COM_FLEXICONTACT_LIST_DESC" >
            <option value="disabled">COM_FLEXICONTACT_V_DISABLED</option>
            <option value="optional">COM_FLEXICONTACT_V_OPTIONAL</option>
            <option value="mandatory">COM_FLEXICONTACT_V_MANDATORY</option>
        </field>
        <field name="list_prompt" type="text" label="COM_FLEXICONTACT_V_PROMPT" default="" />
        <field name="list_list" type="textarea" rows="3" cols="40" label="COM_FLEXICONTACT_V_LIST_ITEMS" default="" 
            description="COM_FLEXICONTACT_V_LIST_ITEMS_DESC" />
                                    
	</fieldset>

   	<fieldset name="opt_fields" class="lad-fieldset width-auto">
        <field name="fields-heading" type="note" label="COM_FLEXICONTACT_OPTIONAL_FIELDS" />
        <field type="spacer" name="heading3" class="text" label="COM_FLEXICONTACT_V_TEXT_FIELD_DESC" />
        
        <field name="field_opt1" type="list" default="1" label="COM_FLEXICONTACT_FIELD_1" >
            <option value="disabled">COM_FLEXICONTACT_V_DISABLED</option>
            <option value="optional">COM_FLEXICONTACT_V_OPTIONAL</option>
            <option value="mandatory">COM_FLEXICONTACT_V_MANDATORY</option>
        </field>
        <field name="field_prompt1" type="text" class="input-xlarge" label="COM_FLEXICONTACT_V_PROMPT" default="" />
        
        <field name="field_opt2" type="list" default="1" label="COM_FLEXICONTACT_FIELD_2" >
            <option value="disabled">COM_FLEXICONTACT_V_DISABLED</option>
            <option value="optional">COM_FLEXICONTACT_V_OPTIONAL</option>
            <option value="mandatory">COM_FLEXICONTACT_V_MANDATORY</option>
        </field>
        <field name="field_prompt2" type="text" class="input-xlarge" label="COM_FLEXICONTACT_V_PROMPT" default="" />

        <field name="field_opt3" type="list" default="1" label="COM_FLEXICONTACT_FIELD_3" >
            <option value="disabled">COM_FLEXICONTACT_V_DISABLED</option>
            <option value="optional">COM_FLEXICONTACT_V_OPTIONAL</option>
            <option value="mandatory">COM_FLEXICONTACT_V_MANDATORY</option>
        </field>
        <field name="field_prompt3" type="text" class="input-xlarge" label="COM_FLEXICONTACT_V_PROMPT" default="" />

        <field name="field_opt4" type="list" default="1" label="COM_FLEXICONTACT_FIELD_4" >
            <option value="disabled">COM_FLEXICONTACT_V_DISABLED</option>
            <option value="optional">COM_FLEXICONTACT_V_OPTIONAL</option>
            <option value="mandatory">COM_FLEXICONTACT_V_MANDATORY</option>
        </field>
        <field name="field_prompt4" type="text" class="input-xlarge" label="COM_FLEXICONTACT_V_PROMPT" default="" />

        <field name="field_opt5" type="list" default="1" label="COM_FLEXICONTACT_FIELD_5" >
            <option value="disabled">COM_FLEXICONTACT_V_DISABLED</option>
            <option value="optional">COM_FLEXICONTACT_V_OPTIONAL</option>
            <option value="mandatory">COM_FLEXICONTACT_V_MANDATORY</option>
        </field>
        <field name="field_prompt5" type="text" class="input-xlarge" label="COM_FLEXICONTACT_V_PROMPT" default="" />

	</fieldset>
        
</form>
