<?xml version="1.0" encoding="utf-8"?>
<extension
	type="module"
	version="2.5"
	client="administrator"
	method="upgrade">
	<name>mod_bo_resetarticlehits</name>
	<author>Alfred Bösch</author>
	<creationDate>July 2012</creationDate>
	<copyright>Copyright (C) 2012 Alfred Bösch. All rights reserved.</copyright>
	<license>GNU General Public License version 2 or later; see LICENSE.txt</license>
	<authorEmail>info@boeschung.de</authorEmail>
	<authorUrl>www.boeschung.de</authorUrl>
	<version>1.4.0</version>
	<description>MOD_BO_RESETARTICLEHITS_XML_DESCRIPTION</description>
	<files>
		<filename module="mod_bo_resetarticlehits">mod_bo_resetarticlehits.php</filename>
		<filename>helper.php</filename>
		<filename>index.html</filename>
		<folder>tmpl</folder>
	</files>
	<languages folder="language">
		<language tag="de-DE">de-DE/de-DE.mod_bo_resetarticlehits.ini</language>
		<language tag="de-DE">de-DE/de-DE.mod_bo_resetarticlehits.sys.ini</language>
		<language tag="en-GB">en-GB/en-GB.mod_bo_resetarticlehits.ini</language>
		<language tag="en-GB">en-GB/en-GB.mod_bo_resetarticlehits.sys.ini</language>
	</languages>
	<config>
		<fields name="params">
			<fieldset name="basic">
				<field
					name="user_id"
					type="list"
					default="0"
					label="MOD_BO_RESETARTICLEHITS_FIELD_AUTHORS_LABEL"
					description="MOD_BO_RESETARTICLEHITS_FIELD_AUTHORS_DESC">
					<option
						value="0">MOD_BO_RESETARTICLEHITS_FIELD_VALUE_ANYONE</option>
					<option
						value="by_me">MOD_BO_RESETARTICLEHITS_FIELD_VALUE_ADDED_OR_MODIFIED_BY_ME</option>
					<option
						value="not_me">MOD_BO_RESETARTICLEHITS_FIELD_VALUE_NOT_ADDED_OR_MODIFIED_BY_ME</option>
				</field>
			</fieldset>
			<fieldset
				name="advanced">
				<field
					name="layout"
					type="modulelayout"
					label="JFIELD_ALT_LAYOUT_LABEL"
					description="JFIELD_ALT_MODULE_LAYOUT_DESC" />

				<field
					name="moduleclass_sfx"
					type="text"
					label="COM_MODULES_FIELD_MODULECLASS_SFX_LABEL"
					description="COM_MODULES_FIELD_MODULECLASS_SFX_DESC" />

				<field
					name="cache"
					type="list"
					default="0"
					label="COM_MODULES_FIELD_CACHING_LABEL"
					description="COM_MODULES_FIELD_CACHING_DESC">
					<option
						value="0">COM_MODULES_FIELD_VALUE_NOCACHING</option>
				</field>

				<field
					name="automatic_title"
					type="radio"
					default="0"
					label="COM_MODULES_FIELD_AUTOMATIC_TITLE_LABEL"
					description="COM_MODULES_FIELD_AUTOMATIC_TITLE_DESC">
					<option
						value="0">JNO</option>
					<option
						value="1">JYES</option>
				</field>
			</fieldset>
		</fields>
	</config>
	<updateservers>
		<server type="extension" priority="1" name="bo:ResetArticleHits Update Site">http://updates.boeschung.de/bo_resetarticlehits-update.xml</server>
	</updateservers>
</extension>
