# Joomla .gitignore file

# Core files and directories that should not be committed
configuration.php
cache/
logs/
tmp/
administrator/cache/
administrator/logs/
administrator/tmp/

# Media files - especially large video files
media/com_spidervideoplayer/upload/*.mp4
media/com_spidervideoplayer/upload/*.avi
media/com_spidervideoplayer/upload/*.mov
media/com_spidervideoplayer/upload/*.wmv
media/com_spidervideoplayer/upload/*.flv
media/com_spidervideoplayer/upload/*.webm
media/com_spidervideoplayer/upload/*.mkv

# General media files (uncomment if needed)
# media/**/*.mp4
# media/**/*.avi
# media/**/*.mov
# media/**/*.wmv
# media/**/*.flv
# media/**/*.webm
# media/**/*.mkv

# User uploaded files
images/banners/
images/sampledata/
images/headers/
images/phocagallery/

# Backup files
*.backup
*.bak
*.old
*.tmp
*.swp
*~

# IDE and editor files
.vscode/
.idea/
*.sublime-*
.DS_Store
Thumbs.db

# Composer and npm
node_modules/
vendor/

# Logs and error files
error_log
*.log

# Joomla specific
installation/
!installation/index.php
!installation/license.txt

# Development files
*.dev
*.local

# Environment files
.env
.env.local
.env.*.local

# Cache and session files
*.cache
*.session

# Temporary upload directories
upload/
uploads/

# Specific to Spider Video Player
media/com_spidervideoplayer/cache/
media/com_spidervideoplayer/temp/
media/com_spidervideoplayer/thumbnails/