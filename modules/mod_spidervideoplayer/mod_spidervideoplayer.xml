<?xml version="1.0" encoding="utf-8" ?>

<extension type="module" client="site" version="3.0" method="upgrade">
  <name>Spider Video Player Module</name>
  <license>GNU/GPLv3 http://www.gnu.org/licenses/gpl-3.0.html</license>
  <author>Web Dorado</author>
  <creationDate>June 2012</creationDate>
  <copyright>Copyright (C) Web-dorado</copyright>
  <authorEmail>info@web-dorado.com</authorEmail>
  <authorUrl>http://web-dorado.com/</authorUrl>
        <version>2.8.9</version> 
  <description>Spider Video Player for Joomla! is a video player extension that allows you to easily add videos to your website with the possibility of organizing videos into playlists and choosing a preferred layout for the player.</description>
	<files>
    	<filename module="mod_spidervideoplayer">mod_spidervideoplayer.php</filename>
 		<filename>index.html</filename>
	</files>
<config>
  <fields name="params">

  	<fieldset name="basic" label="Module Parameters">
	<field name="priority" type="radio" default="flash" label="Priority">
	<option value="flash">Flash</option>
	<option value="html5">HTML5</option>
	</field>

		<field name="typeselect" type="typeselect" default="0" label="type_select" description="type_select" />

		<field name="theme" type="theme" default="-1" label="Select Theme" description="Select Theme" required=""  addfieldpath="/administrator/components/com_spidervideoplayer/elements/" />
		
		
		<field name="playlist" type="playlist" default="" label="Playlist" description="Playlist" required=""  addfieldpath="/administrator/components/com_spidervideoplayer/elements/" />
	
			<field name="video" type="video" default="" label="Video" description="Video" />
	
	</fieldset>
  </fields>
</config>

</extension>

